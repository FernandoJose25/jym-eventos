+      setCtrlVisible(true);
+    }
+  }, [panel]);
+
+  const bump = () => {
+    setCtrlVisible(true);
+    clearTimeout(timerRef.current);
+    // Solo auto-ocultar si no hay panel abierto — leer del estado directamente
+    // via un setState funcional para tener el valor actual sin closure stale
+    setPanel(p => {
+      if (p === 'none') {
