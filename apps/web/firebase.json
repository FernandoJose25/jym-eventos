{
  "firestore": {
    "database": "(default)",
    "location": "us-central1",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": "public",
    "redirects": [
      {
        "source": "/:path*",
        "destination": "https://jmdecoracionesyeventos.com/:path",
        "type": 301
      },
      {
        "source": "**",
        "destination": "https://jmdecoracionesyeventos.com",
        "type": 301
      }
    ]
  }
}