{
  "firestore": {
    "database": "(default)",
    "location": "us-central1",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": "public",
    "redirects": [
      {
        "source": "/:path*",
        "destination": "https://jmdecoracionesyeventos.vercel.app/:path",
        "type": 301
      },
      {
        "source": "**",
        "destination": "https://jmdecoracionesyeventos.vercel.app",
        "type": 301
      }
    ]
  }
}