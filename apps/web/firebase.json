{
  "firestore": {
    "database": "(default)",
    "location": "us-central1",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": "public",
    "redirects": [
      {
        "source": "/**",
        "destination": "https://jym-eventos-web.vercel.app/:splat",
        "type": 301
      }
    ]
  }
}