rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Lecturas públicas (site_config, services, gallery, testimonials, etc.)
    match /{document=**} {
      allow read: if true;
    }

    // Escrituras autenticadas (panel admin)
    match /{document=**} {
      allow write: if request.auth != null;
    }

    // Formulario de contacto — cualquier visitante puede crear un mensaje
    match /mensajes/{id} {
      allow create: if
        request.resource.data.nombre is string &&
        request.resource.data.nombre.size() >= 2 &&
        request.resource.data.telefono is string &&
        request.resource.data.telefono.size() >= 6 &&
        request.resource.data.correo is string;
    }

    // Cámara Invitado — un invitado sin sesión puede subir una foto/video a
    // un álbum concreto (el endpoint /api/camara-invitado/sign ya validó que
    // el token existe y está activo antes de firmar el upload a Cloudinary;
    // esta regla solo valida la forma del documento que crea en Firestore).
    // visible puede ser true o false: las fotos de invitado se publican
    // automáticamente en el álbum sin aprobación manual.
    match /gallery_items/{id} {
      allow create: if
        request.resource.data.origen == 'invitado' &&
        request.resource.data.albumId is string &&
        request.resource.data.albumId.size() > 0 &&
        request.resource.data.url is string &&
        request.resource.data.url.size() > 0 &&
        request.resource.data.tipo in ['imagen', 'video'] &&
        request.resource.data.visible is bool;
    }
  }
}
