rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Lecturas públicas (site_config, services, gallery, testimonials, etc.)
    match /{document=**} {
      allow read: if true;
    }

    function rolDe(uid) {
      return get(/databases/$(database)/documents/usuarios/$(uid)).data.rol;
    }
    function esAdmin() {
      return request.auth != null && rolDe(request.auth.uid) == 'admin';
    }
    function esEditor() {
      return request.auth != null &&
        (rolDe(request.auth.uid) == 'admin' || rolDe(request.auth.uid) == 'editor');
    }

    // Colección de usuarios: cualquier cuenta autenticada puede crear su
    // propio doc (primer login) y editar sus propios datos, pero NO puede
    // cambiar su propio rol — eso solo lo hace un admin. Evita que una
    // cuenta 'lector' se autoasigne 'admin' escribiendo directo a Firestore.
    match /usuarios/{uid} {
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if esAdmin() ||
        (request.auth.uid == uid && request.resource.data.rol == resource.data.rol);
      allow delete: if esAdmin();
    }

    // Resto de colecciones del panel admin: exige rol editor/admin real,
    // no solo "estar autenticado" (antes cualquier cuenta autenticada,
    // incluida 'lector', podía escribir cualquier cosa).
    match /{document=**} {
      allow write: if esEditor();
    }

    // El formulario de contacto ya NO escribe directo a Firestore — pasa por
    // /api/contacto (Admin SDK, ignora estas reglas), que aplica rate
    // limiting, honeypot y validación real de servidor. Sin regla pública de
    // create aquí a propósito: el catch-all de arriba (esEditor()) es la
    // única vía de escritura para 'mensajes' desde el cliente.

    // Cámara Invitado — un invitado sin sesión puede subir una foto/video a
    // un álbum concreto. /api/camara-invitado/sign ya validó el token antes
    // de firmar el upload a Cloudinary, pero esta regla es una puerta
    // independiente (cualquiera puede llamar al SDK cliente directo), así
    // que valida por su cuenta: (a) la URL debe venir de Cloudinary — cierra
    // la inyección de contenido arbitrario (imágenes/URLs ajenas a lo que el
    // propio flujo de subida genera); (b) debe existir el álbum destino —
    // cierra el caso de escribir a un albumId inventado que no existe.
    // NOTA: no ata la escritura a un token específico de Cámara Invitado ni
    // verifica que ese álbum tenga la Cámara activa — camara_invitado_links
    // se indexa por token vía query (no por id de doc), y las Firestore
    // Rules no soportan where(), solo get()/exists() por path exacto. Cerrar
    // esa parte requeriría cambiar el modelo de datos (ej. usar albumId como
    // id del doc del link) — queda fuera de este cambio.
    match /gallery_items/{id} {
      allow create: if
        request.resource.data.origen == 'invitado' &&
        request.resource.data.albumId is string &&
        request.resource.data.albumId.size() > 0 &&
        request.resource.data.url is string &&
        request.resource.data.url.matches('^https://res[.]cloudinary[.]com/.*') &&
        request.resource.data.tipo in ['imagen', 'video'] &&
        request.resource.data.visible is bool &&
        exists(/databases/$(database)/documents/albums/$(request.resource.data.albumId));
    }
  }
}
